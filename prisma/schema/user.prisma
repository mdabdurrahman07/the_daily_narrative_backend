model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(255)
    email        String       @unique
    password     String
    activeStatus activeStatus @default(ACTIVE)
    role         Role         @default(USER)
    profile      Profile?
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt

    @@map("users")
}

enum activeStatus {
    ACTIVE
    BLOCKED
}

enum Role {
    AUTHOR
    USER
    ADMIN
}
